# Stage 1: Build
FROM rust:latest AS builder

WORKDIR /app

# install protoc
RUN apt-get update && apt-get install -y protobuf-compiler

COPY . .

RUN cargo build --release

# Stage 2: Runtime
FROM debian:bookworm-slim

WORKDIR /usr/local/bin

COPY --from=builder /app/target/release/rustride .

CMD ["./rustride"]