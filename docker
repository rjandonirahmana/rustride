# Stage 1: Build
FROM rustlang/rust:nightly-alpine AS builder

RUN apk add --no-cache \
    musl-dev \
    protobuf-dev \
    g++ \
    make \
    perl \
    pkgconfig \
    openssl-dev \
    openssl-libs-static \
    zlib-dev \
    zlib-static

WORKDIR /app
COPY . .

# Paksa openssl-sys pakai vendored (compile OpenSSL dari source, static link)
ENV OPENSSL_STATIC=1
ENV OPENSSL_VENDORED=1

RUN cargo build --release --target x86_64-unknown-linux-musl

# Stage 2: Runtime — pakai scratch karena fully static binary
FROM scratch
COPY --from=builder /app/target/x86_64-unknown-linux-musl/release/ridehailing /ridehailing
CMD ["/ridehailing"]